# =================================
# Auditor Data Integration Platform
# Environment Configuration
# =================================

# Application
APP_NAME=Auditor Data Integration Platform
APP_VERSION=1.0.0
DEBUG=true

# MongoDB
MONGODB_URL=mongodb+srv://by8labs:By8labs007@by8labs.ewd7q.mongodb.net/?appName=by8labs
MONGODB_DB_NAME=audit_platform

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# CORS Origins (comma-separated list handled by Pydantic)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# Mock Data Mode (set to false when connecting to real APIs)
USE_MOCK_DATA=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
